# Footy Mind - Environment Variables

# 1. API-Football (For Live Match Data)
# Get this from https://www.api-football.com/
VITE_FOOTBALL_API_KEY="your_api_key_here"

# 2. Groq AI (For Daily Unique Quiz Generation fallback)
# Get this from https://console.groq.com/
VITE_GROQ_API_KEY="your_groq_api_key_here"

# 3. Custom Python Backend (BYOK Architecture)
# The React app will send requests to this local Python backend.
# The user will provide their API key via the UI or you can hardcode it here for local testing.
VITE_API_BASE_URL="http://localhost:8000"
VITE_IBM_CLOUD_IAM_APIKEY="your_ibm_cloud_iam_apikey_here"
VITE_WATSONX_PROJECT_ID="your_watsonx_project_id_here"
VITE_WATSONX_ENDPOINT="https://eu-de.ml.cloud.ibm.com"

# 5. Docling MCP
VITE_DOCLING_ENDPOINT="http://localhost:5000/parse"

# 4. Firebase (For Auth & Firestore Persistence)
# Go to Firebase Console -> Project Settings -> General -> Web App
VITE_FIREBASE_API_KEY="your_firebase_api_key"
VITE_FIREBASE_AUTH_DOMAIN="your_project.firebaseapp.com"
VITE_FIREBASE_PROJECT_ID="your_project_id"
VITE_FIREBASE_STORAGE_BUCKET="your_project.appspot.com"
VITE_FIREBASE_MESSAGING_SENDER_ID="your_sender_id"
VITE_FIREBASE_APP_ID="your_app_id"
