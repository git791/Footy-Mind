# Footy Mind - Environment Variables

# 1. API-Football (For Live Match Data)
# Get this from https://www.api-football.com/
VITE_FOOTBALL_API_KEY="your_api_key_here"

# 2. Groq AI (For Daily Unique Quiz Generation fallback)
# Get this from https://console.groq.com/
VITE_GROQ_API_KEY="your_groq_api_key_here"

# 3. Langflow + ContextForge Pipeline
# --- HOW TO GET LANGFLOW KEYS (IBM SkillsBuild Challenge) ---
# Since you are participating in the IBM SkillsBuild AI Builders Challenge powered by BeMyApp:
# DataStax AstraDB is NOT the official provisioner for this challenge. 
# 1. Log in to the official challenge portal: https://ibmskillsbuildchallenge.bemyapp.com/
# 2. Navigate to the "Getting Started" or "Resources" section on your participant dashboard.
# 3. Follow the specific instructions provided there to launch the sanctioned Langflow workspace (usually via IBM Cloud or a dedicated Sandbox environment).
# 4. Once inside Langflow, click "API" -> "cURL" in the top right to reveal your endpoint URL and Application Token.
VITE_LANGFLOW_API_URL="your_langflow_api_url_here"
VITE_LANGFLOW_APPLICATION_TOKEN="your_langflow_application_token_here"

# --- HOW TO GET CONTEXT FORGE KEYS (IBM/BeMyApp Monthly Challenge) ---
# ContextForge uses its own Admin UI Dashboard to generate JWT tokens.
# 1. Launch ContextForge (either via the link on the BeMyApp participant dashboard, or if you are running it locally via Docker/CLI: `mcp-context-forge`).
# 2. Access the ContextForge Admin UI (often hosted at paths like `/admin/observability/tools`).
# 3. Navigate to the "Tokens" section and generate a new JWT token to connect Langflow to external tools.
# 4. Note the generated Token (API Key) and the Gateway URL.
VITE_CONTEXTFORGE_API_KEY="your_contextforge_key_here"
VITE_CONTEXTFORGE_GATEWAY_URL="your_contextforge_gateway_url_here"

# 4. IBM WatsonX / Granite
VITE_IBM_CLOUD_IAM_APIKEY="your_ibm_cloud_iam_apikey_here"
VITE_WATSONX_PROJECT_ID="your_watsonx_project_id_here"

# 5. Docling MCP
VITE_DOCLING_ENDPOINT="http://localhost:5000/parse"

# 4. Firebase (For Auth & Firestore Persistence)
# Go to Firebase Console -> Project Settings -> General -> Web App
VITE_FIREBASE_API_KEY="your_firebase_api_key"
VITE_FIREBASE_AUTH_DOMAIN="your_project.firebaseapp.com"
VITE_FIREBASE_PROJECT_ID="your_project_id"
VITE_FIREBASE_STORAGE_BUCKET="your_project.appspot.com"
VITE_FIREBASE_MESSAGING_SENDER_ID="your_sender_id"
VITE_FIREBASE_APP_ID="your_app_id"
